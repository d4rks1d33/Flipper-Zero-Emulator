# WS1 determinism test harness.
# Boots to desktop, hooks loader_show_menu, injects N OK presses with precise
# timing and counts how many open the menu.
#
# Set $firmware_bin before include.

include @scripts/flash_firmware.resc

# Let it boot to the desktop.
emulation RunFor "42"

# Hook loader_show_menu (real entry 0x08087aba). Each hit = menu open request.
cpu AddHook 0x08087aba "print 'MENU_OPENED'"

echo "=== BOOT DONE, STARTING PRESS TEST ==="
