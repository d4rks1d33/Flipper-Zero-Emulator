# ─── Renode tooling ──────────────────────────────────────────────────────────
# The working copy of Renode (extracted by install.sh) is NOT tracked — it is
# reproduced from tools/renode-prebuilt/ or built from third_party/renode-src/.
/tools/renode/
# Locally bootstrapped .NET SDK (only when building Renode from source).
/tools/dotnet/
/tools/dotnet-install.sh
/tools/renode.tar.gz
# TRACKED (do NOT ignore): tools/renode-prebuilt/ (shipped patched binaries) and
# tools/renode-patches/ (the persistence patch).

# ─── Renode source build artifacts ──────────────────────────────────────────
# The patched Renode SOURCE (third_party/renode-src) IS tracked, but its build
# outputs are not.
/third_party/renode-src/output/
third_party/renode-src/**/obj/
third_party/renode-src/**/bin/

# ─── Generated per-machine files (created from *.in by setup.sh) ─────────────
/platform/stm32wb55_flipper.repl
/scripts/run_updater.resc
/scripts/flash_firmware.resc
/scripts/update_manifest_params.resc

# ─── Runtime artifacts ───────────────────────────────────────────────────────
/logs/*.jsonl
/sdcard/*.img
/tmp/
*.raw

# ─── Firmware / flash images ─────────────────────────────────────────────────
# Large or machine-specific; regenerated by setup.sh / run.sh.
/firmware/*.dfu
/firmware/*.tgz
/firmware/*.elf
/firmware/flash.img
# NOTE: the bundled stock firmware/*.bin and firmware/resources.ths ARE tracked
# so the emulator runs out of the box (they are not ignored).
!/firmware/flipper_emulator.patch

# ─── Python / Editor / OS ────────────────────────────────────────────────────
__pycache__/
*.pyc
*.swp
.DS_Store
