 bool furi_hal_power_sleep_available(void) {
+#ifdef FLIPPER_EMULATOR
+    /* Emulator patch: disable tickless-idle deep sleep. It relies on the LPTIM1
+     * wake-up interrupt to resume threads that call furi_delay_tick(); under
+     * functional emulation that wake path is unreliable and starves the input
+     * debounce loop (buttons never register). Returning false makes the idle
+     * task use plain __WFI(), which Renode wakes on the SysTick interrupt, so
+     * furi_delay_tick() and button debounce work normally. */
+    return false;
+#else
     return furi_hal_power.insomnia == 0;
+#endif
 }
 
