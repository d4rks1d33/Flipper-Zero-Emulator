<Project DefaultTargets="Build" Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <NoWarn>SYSLIB0050;SYSLIB0051</NoWarn> <!-- Suppresses, but warn in WarnUser target -->
    <TargetFrameworks>net6.0</TargetFrameworks>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
	  <Deterministic>false</Deterministic>
    <RootNamespace>Antmicro.Migrant</RootNamespace>
    <AssemblyName>Migrant</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
		<PackageReference Include="Microsoft.CSharp" Version="4.7.0" />
		<PackageReference Include="System.Reflection.Emit.ILGeneration" Version="4.7.0" />
		<PackageReference Include="System.Reflection.Emit.Lightweight" Version="4.7.0" />
  </ItemGroup>
  <Target Name="WarnUser" AfterTargets="PostBuildEvent" >
    <Warning Text="{SYSLIB0050, SYSLIB0051}: Migrant uses obsolete formatter-based serialization" />
  </Target>
</Project>
